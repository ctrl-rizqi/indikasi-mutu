{
  "name": "@repo/backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc && cp -r prisma dist/ && cp package.json dist/",
    "start": "node dist/index.js",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@hono/node-server": "^1.8.2",
    "@prisma/adapter-mariadb": "^6.15.0",
    "@prisma/client": "^6.15.0",
    "@repo/resource": "workspace:*",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.2",
    "hono": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.4.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/config": "^6.17.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.15.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
