{
  "name": "@repo/backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "postbuild": "cp -r prisma dist/ 2>/dev/null || : && cp package.json dist/",
    "start": "node dist/index.js",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@prisma/adapter-mariadb": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@repo/resource": "workspace:*",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.3",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/config": "^7.4.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.2",
    "nodemon": "^3.1.14",
    "prisma": "^7.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
